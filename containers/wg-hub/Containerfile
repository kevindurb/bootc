FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:7a78b5eafa836374803832b2a4edd039b93c37fb02eafc6a1b2e11330dcb5511

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  nebula \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
