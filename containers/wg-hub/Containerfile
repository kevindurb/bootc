FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:97a1b6e1a00d62fc2f74cdaa06fc35d078caa93a4518d32c1948ba1e8e9a2da9

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
