FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:0977694a89f3cd0a56f6eded9e548932ac96de2f793606fe3c5637a6988f27f0

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  nebula \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
