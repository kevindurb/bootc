FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:ee36fd06bbc470e90964014d4523d8ea636f31bef55a2afc62b432367c70c83d

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  nebula \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
