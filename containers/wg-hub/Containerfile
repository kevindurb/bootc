FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:4e7c2e067d6665e49276770a91e3aa3ba6a76b79ec5275f5cae1b8c82fb19c6b

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
