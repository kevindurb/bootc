FROM ghcr.io/ublue-os/ucore-minimal:stable@sha256:ccb22189501fbba50a6bc7ad45b8ca13d84a0a045658f11e5be9357ae620efc8

ARG FILES_ROOT=./containers/wg-hub/files

RUN dnf install -y \
  nebula \
  node-exporter \
  wireguard-tools \
  && dnf clean all

COPY ${FILES_ROOT}/modules.conf /etc/modules-load.d/99-wg.conf
COPY ${FILES_ROOT}/sysctl.conf /etc/sysctl.d/99-wg.conf

RUN bootc container lint
