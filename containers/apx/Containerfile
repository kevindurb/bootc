FROM docker.io/library/golang:1.26@sha256:c83e68f3ebb6943a2904fa66348867d108119890a2c6a2e6f07b38d0eb6c25c5 AS build
WORKDIR /app
# renovate: datasource=github-tags depName=apx packageName=vanilla-os/apx
ARG APX_VERSION=v3.0.1
RUN GOBIN=/app go install github.com/vanilla-os/apx@${APX_VERSION}

FROM scratch
WORKDIR /
COPY --from=build /app/apx .
